---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch non-draft blog posts, sorted by date desc, limited to latest 3
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredProjects = [
   {
  title: "DedupInspector",
  description:
    "Offline Windows Data Deduplication explorer and recovery tool for digital forensics. Reconstructs deduplicated files from an exported $MFT, Stream, and Chunk metadata.",
  tags: [
    "C++",
    "Win32",
    "DFIR",
    "NTFS",
    "Reverse Engineering"
  ],
  github: "https://github.com/7h3kn0w3r/DedupInspector",
  live: "https://7h3kn0w3r.github.io/blog/windows-data-deduplication/"
  },
];
---

<Layout>
<!-- Hero Section -->
<section class="mb-20 md:mb-28">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Left -->
    <div>
      <div class="inline-flex items-center border border-[#B3001B]/30 bg-[#B3001B]/5 px-3 py-1 text-[10px] font-mono uppercase tracking-[0.2em] text-[#B3001B] rounded-sm mb-5">
        Trace ID: #9821-SECURE
      </div>

      <h1 class="font-display font-bold text-4xl md:text-6xl leading-tight">
        Hello, I'm
        <span class="text-white text-glow block">Mostafa Mahmoud</span>
      </h1>

      <p class="mt-4 font-mono uppercase tracking-widest text-sm text-[#B3001B]">
        SOC Analyst • DFIR • Threat Hunter • CTF Player
      </p>

      <p class="mt-6 text-neutral-300 leading-8 max-w-xl">
        Cybersecurity analyst focused on Digital Forensics, Incident Response,
        and Threat Hunting. Passionate about investigating security incidents,
        analyzing attacker behavior, and solving real-world security challenges
        through continuous learning and hands-on research.
      </p>

      <div class="mt-8 flex flex-wrap gap-4 font-mono text-xs uppercase">
        <a
          href="https://github.com/7h3kn0w3r"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-3 border border-[#B3001B] text-white hover:bg-[#B3001B] transition rounded-sm"
        >
          [ GitHub ]
        </a>

        <a
          href="https://www.linkedin.com/in/7h3kn0w3r/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-3 border border-neutral-700 hover:border-white transition rounded-sm"
        >
          [ LinkedIn ]
        </a>

        <a
          href="/resume.pdf"
          class="px-5 py-3 border border-neutral-700 hover:border-white transition rounded-sm"
        >
          [ Resume ]
        </a>
      </div>
    </div>

    <!-- Right -->
    <div class="flex justify-center lg:justify-end">
      <div class="relative">

        <div class="absolute -inset-2 rounded-full border border-[#B3001B]/30 animate-pulse"></div>

        <img
          src="/images/profile.jpg"
          alt="Mostafa Mahmoud"
          class="relative w-72 h-72 object-cover rounded-full border-2 border-[#B3001B] shadow-[0_0_40px_rgba(179,0,27,.25)]"
        />

        <div class="mt-6 border border-neutral-900 bg-[#1b1b1b]/70 p-4 rounded-sm font-mono text-xs">
          <div class="flex justify-between">
            <span class="text-neutral-500">Status</span>
            <span class="text-green-400">ONLINE</span>
          </div>

          <div class="flex justify-between mt-2">
            <span class="text-neutral-500">Focus</span>
            <span class="text-white">DFIR</span>
          </div>

          <div class="flex justify-between mt-2">
            <span class="text-neutral-500">Location</span>
            <span class="text-white">Egypt</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

  <!-- About Preview Section -->
  <section class="mb-20 border-t border-neutral-900 pt-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-1">
        <h2 class="font-display font-bold text-lg uppercase tracking-wider text-glow text-white">
          <span class="text-[#B3001B] font-bold">//</span> About System
        </h2>
        <p class="font-mono text-[10px] text-neutral-500 uppercase mt-1">MODULE_INFO // LOG_STATUS</p>
      </div>
      
      <div class="md:col-span-2 text-sm md:text-base text-neutral-300 space-y-4">
        <p class="leading-relaxed">
          Cybersecurity enthusiast with a strong interest in Security Operations, Digital Forensics, and Incident Response (DFIR). Passionate about incident analysis, understanding attacker behavior, and continuously improving practical security skills through hands-on learning.
        </p>
        <p class="leading-relaxed">
          Active CTF Player driven by curiosity and problem-solving, using challenges and real-world scenarios to strengthen analytical thinking and technical knowledge. Based on the principles of knowledge sharing and responsible research, I document my learning journey, experiments, and writeups for the security community.
        </p>
        <div class="pt-2 font-mono text-xs uppercase">
          <a href="/about" class="text-neutral-400 hover:text-white transition-colors">
            Read complete system dossier <span class="text-[#B3001B]">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section class="mb-20 border-t border-neutral-900 pt-16">
    <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-8">
      <div>
        <h2 class="font-display font-bold text-lg uppercase tracking-wider text-glow text-white">
          <span class="text-[#B3001B] font-bold">//</span> Research & Labs & Tools
        </h2>
        <p class="font-mono text-[10px] text-neutral-500 uppercase mt-1">SECURE_FILES // PORTFOLIO</p>
      </div>
      <a href="/projects" class="font-mono text-xs text-neutral-400 hover:text-white transition-colors mt-2 md:mt-0 uppercase">
        View all projects <span class="text-[#B3001B]">&rarr;</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {featuredProjects.map(project => (
        <div class="terminal-card p-6 flex flex-col justify-between rounded-sm">
          <div>
            <h3 class="font-display font-bold text-sm tracking-wide text-white mb-2">{project.title}</h3>
            <p class="text-xs text-neutral-400 leading-relaxed mb-4">{project.description}</p>
          </div>
          
          <div>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.tags.map(tag => (
                <span class="bg-bg-dark border border-neutral-800 text-[10px] font-mono px-2 py-0.5 text-neutral-400 rounded-sm">
                  {tag}
                </span>
              ))}
            </div>
            
            <div class="flex items-center space-x-3 font-mono text-[10px] uppercase">
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-[#B3001B] hover:text-white transition-colors">
                [ GITHUB ]
              </a>
              {project.live && (
                <span class="text-neutral-700">//</span>
                <a href={project.live} target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-white transition-colors">
                  [ LIVE ]
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Latest Blog Posts Section -->
  <section class="mb-8 border-t border-neutral-900 pt-16">
    <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-8">
      <div>
        <h2 class="font-display font-bold text-lg uppercase tracking-wider text-glow text-white">
          <span class="text-[#B3001B] font-bold">//</span> Forensic Writeups
        </h2>
        <p class="font-mono text-[10px] text-neutral-500 uppercase mt-1">LOGS // BLOG_WRITEUPS</p>
      </div>
      <a href="/blog" class="font-mono text-xs text-neutral-400 hover:text-white transition-colors mt-2 md:mt-0 uppercase">
        Browse all writeups <span class="text-[#B3001B]">&rarr;</span>
      </a>
    </div>

    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.id}/`} class="block terminal-card p-6 rounded-sm relative overflow-hidden group">
          <div class="absolute left-0 top-0 w-1 h-full bg-neutral-900 group-hover:bg-[#B3001B] transition-colors"></div>
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
              <div class="flex items-center space-x-3 text-[10px] font-mono text-neutral-400 uppercase mb-2">
                <span>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                <span class="text-neutral-700">//</span>
                <span class="text-[#B3001B]">{post.data.category}</span>
              </div>
              <h3 class="font-display font-bold text-base text-white group-hover:text-glow transition-all">{post.data.title}</h3>
              <p class="text-xs text-neutral-400 mt-1 max-w-2xl leading-relaxed">{post.data.description}</p>
            </div>
            
            <div class="flex flex-wrap gap-1.5 md:justify-end">
              {post.data.tags.slice(0, 3).map(tag => (
                <span class="bg-bg-dark border border-neutral-950 text-[9px] font-mono px-2 py-0.5 text-neutral-500 rounded-sm">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

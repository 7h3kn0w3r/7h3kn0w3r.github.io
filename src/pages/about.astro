---
import Layout from '../layouts/Layout.astro';

const skills = [
  { category: "DFIR", items: ["Volatility", "Autopsy", "FTK Imager", "Registry Forensics", "wireshark", "chainsaw", "ERIC Zimmermen Tools"] },
  { category: "Threat Hunting", items: ["ٍSplunk", "ELK", "Wazuh", "Velociraptor"] },
  { category: "CTFS", items: ["OSINT", "DFIR", "STEGO", "CRYPTO"] },
  { category: "Soft Skills", items: ["Analytical Thinking", "Attention to Detail", "Team Collaboration", "Research Mindset"] }
];

const timeline = [
  {
    date: "2026 - Present",
    description: "Ongoing attempts to secure a job"
  },
  {
    date: "2025-12-29",
    role: "eCTHP",
    company: "INE",
    description: "professional-level certification that proves your threat hunting and threat identification capabilities."
  },
  {
    date: "2025-4-24",
    role: "Aswan CTF",
    company: "1st Upper Egypt",
    description: "My First Offline CTF"
  }
];
---

<Layout title="About // 7h3kn0w3r " description="Biography, technical skills matrix, and professional footprint timeline.">
  <section class="max-w-3xl">
    <!-- Dossier Header -->
    <div class="mb-12 border-b border-neutral-900 pb-8">
      <div class="inline-block border border-accent/30 bg-accent/5 px-2.5 py-1 text-[10px] font-mono tracking-widest text-accent uppercase mb-3">
        Dossier Type: PERSONNEL_FILE_0x44
      </div>
      <h1 class="font-display font-bold text-3xl tracking-tight mb-2">Personnel File</h1>
      <p class="font-mono text-xs text-neutral-400 uppercase tracking-widest">Operator: Mostafa Mahmoud</p>
    </div>

    <!-- Biography -->
    <div class="text-sm md:text-base text-neutral-300 space-y-6 leading-relaxed mb-16">
      <p>
        I am a cybersecurity analyst with a strong focus on digital forensics, incident response, and threat hunting. I enjoy investigating security incidents and reconstructing attacker activity through evidence-driven analysis.
      </p>
      <p>
        My work includes memory forensics, Windows event log analysis, malware investigation, and SIEM-based detection. I focus on understanding attacker techniques and turning forensic findings into actionable security insights.
      </p>
      <p>
        I continuously improve my skills through DFIR labs, CTF competitions, and security research, with the goal of helping organizations detect, investigate, and respond to modern cyber threats.
      </p>
    </div>

    <!-- Technical Skills Matrix -->
    <div class="mb-16">
      <h2 class="font-display font-bold text-sm uppercase tracking-widest mb-6 text-white border-b border-neutral-900 pb-2">
        <span class="text-accent">//</span> Skill Matrix
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {skills.map(group => (
          <div class="border border-neutral-900 bg-[#1F1F2E]/30 p-5 rounded-sm">
            <h3 class="font-display font-bold text-xs text-white uppercase tracking-wider mb-3">{group.category}</h3>
            <ul class="space-y-1.5 font-mono text-xs text-neutral-400">
              {group.items.map(item => (
                <li class="flex items-center">
                  <span class="text-accent mr-2 font-bold">-</span> {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Career Footprint -->
    <div>
      <h2 class="font-display font-bold text-sm uppercase tracking-widest mb-8 text-white border-b border-neutral-900 pb-2">
        <span class="text-accent">//</span> Footprint Timeline
      </h2>
      
      <div class="relative border-l border-neutral-800 ml-3 pl-6 space-y-10 font-mono">
        {timeline.map(item => (
          <div class="relative">
            <!-- Timeline dot -->
            <div class="absolute -left-[31px] top-1.5 w-2.5 h-2.5 bg-bg-dark border border-accent rounded-full flex items-center justify-center">
              <div class="w-1 h-1 bg-accent rounded-full"></div>
            </div>
            
            <div class="text-[10px] text-accent font-bold mb-1 uppercase tracking-wider">{item.date}</div>
            <h3 class="text-sm font-bold text-white uppercase">{item.role}</h3>
            <div class="text-xs text-neutral-400 uppercase mt-0.5">{item.company}</div>
            <p class="text-xs text-neutral-400 font-sans mt-3 leading-relaxed max-w-2xl">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
